local CurrentQuestName = ""
local CurrentMobName = ""

function CheckQuestAndMob()
    local myLevel = LocalPlayer.Data.Level.Value
    if myLevel >= 1 and myLevel < 15 then CurrentQuestName = "BanditQuest1" CurrentMobName = "Bandit"
    elseif myLevel >= 15 and myLevel < 30 then CurrentQuestName = "MonkeyQuest1" CurrentMobName = "Monkey"
    else CurrentQuestName = "BanditQuest1" CurrentMobName = "Bandit" end
end

task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.AutoFarmLevel then
            pcall(function()
                CheckQuestAndMob()
                local hasQuest = LocalPlayer.PlayerGui.Main:FindFirstChild("Quest") and LocalPlayer.PlayerGui.Main.Quest.Visible
                if not hasQuest then
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", CurrentQuestName, 1)
                else
                    local targetMob = nil
                    for _, mob in pairs(workspace.Enemies:GetChildren()) do
                        if mob.Name == CurrentMobName and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                            targetMob = mob
                            break
                        end
                    end
                    if targetMob and targetMob:FindFirstChild("HumanoidRootPart") then
                        ToTween(targetMob.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0))
                        if _G.AutoAttack then
                            VirtualUser:CaptureController()
                            VirtualUser:ClickButton1(Vector2.new(50, 50))
                        end
                        if _G.BringMob then
                            for _, otherMob in pairs(workspace.Enemies:GetChildren()) do
                                if otherMob.Name == CurrentMobName and otherMob ~= targetMob and otherMob:FindFirstChild("HumanoidRootPart") then
                                    otherMob.HumanoidRootPart.CFrame = targetMob.HumanoidRootPart.CFrame
                                    otherMob.HumanoidRootPart.CanCollide = false
                                end
                            end
                        end
                    else
                        for _, spawnPoint in pairs(workspace._WorldOrigin.EnemySpawns:GetChildren()) do
                            if string.find(spawnPoint.Name, CurrentMobName) then
                                ToTween(spawnPoint.CFrame * CFrame.new(0, 20, 0))
                                break
                            end
                        end
                    end
                end
            end)
        end
    end
end)

