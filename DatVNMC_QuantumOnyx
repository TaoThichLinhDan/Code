-- [HÀM DỊCH CHUYỂN TWEEN AN TOÀN]
-- ====================================================================
function ToTween(pos)
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local distance = (pos.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
    local speed = 300
    local tweenInfo = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(LocalPlayer.Character.HumanoidRootPart, tweenInfo, {CFrame = pos})
    tween:Play()
    return tween
end

